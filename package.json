{
  "name": "flowent",
  "version": "0.0.1",
  "description": "A workflow orchestration platform for multi-agent collaboration.",
  "author": "ImFeH2 <i@feh2.im>",
  "license": "Apache-2.0",
  "private": false,
  "bin": {
    "flowent": "bin/flowent.mjs"
  },
  "files": [
    "assets/",
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ImFeH2/flowent.git"
  },
  "bugs": {
    "url": "https://github.com/ImFeH2/flowent/issues"
  },
  "homepage": "https://github.com/ImFeH2/flowent#readme",
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "pnpm@10.29.3",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "next dev -p 6873",
    "build": "next build",
    "build:npm": "pnpm build && node scripts/prepare-npm-package.mjs",
    "start": "next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "release-it --dry-run",
    "release:exec": "release-it",
    "prepack": "pnpm build:npm",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,mts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,jsonc,md,mdx,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "release-it": "^20.0.1",
    "shadcn": "^4.5.0",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
